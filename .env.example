# Application Configuration
SPRING_APPLICATION_NAME=food-store

# Database Configuration
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3308/foodstore?useUnicode=true&characterEncoding=UTF-8&useSSL=false&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=123456
SPRING_DATASOURCE_DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver

# JPA/Hibernate Configuration
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# File Upload Configuration
SPRING_SERVLET_MULTIPART_ENABLED=true
SPRING_SERVLET_MULTIPART_MAX_FILE_SIZE=50MB
SPRING_SERVLET_MULTIPART_MAX_REQUEST_SIZE=50MB

# Session Configuration
SPRING_SESSION_STORE_TYPE=jdbc
SPRING_SESSION_TIMEOUT=30m
SPRING_SESSION_JDBC_INITIALIZE_SCHEMA=always

# Email Configuration
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=your_email@gmail.com
SPRING_MAIL_PASSWORD=your_app_password
SPRING_MAIL_SMTP_AUTH=true
SPRING_MAIL_SMTP_STARTTLS_ENABLE=true

# OAuth2 - Google Configuration
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_SCOPE=email,profile

# OAuth2 - GitHub Configuration
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Static Resources Configuration
SPRING_WEB_RESOURCES_ADD_MAPPINGS=false

# RabbitMQ Configuration
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# VNPay Configuration
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:8081/afterOrder

# Gemini AI API Configuration
API_GEMINI_URL=

# Server Configuration (uncomment if needed)
SERVER_PORT=8081
